# ╔══════════════════════════════════════════════════════════════╗
# ║              HR AI 系统 - 环境变量配置模板                       ║
# ║  复制此文件为 .env，填入真实值后再启动                              ║
# ╚══════════════════════════════════════════════════════════════╝

# ────────────────────────────────────────────────
# 应用访问地址
# ────────────────────────────────────────────────
# 本地访问地址（浏览器打开此地址）
APP_URL=http://localhost:3210
# 容器内部自调用地址（勿改）
INTERNAL_APP_URL=http://localhost:3210
# LobeHub 监听端口
LOBE_PORT=3210

# ────────────────────────────────────────────────
# 认证安全密钥（必填，至少32位随机字符串）
# 生成方法：openssl rand -base64 32
# ────────────────────────────────────────────────
AUTH_SECRET=REPLACE_WITH_32_CHAR_RANDOM_STRING_HERE_xxxx

# ────────────────────────────────────────────────
# PostgreSQL 数据库
# ────────────────────────────────────────────────
POSTGRES_PASSWORD=HrAI_DB_2024_SecurePass!
LOBE_DB_NAME=hr_lobechat

# ────────────────────────────────────────────────
# Redis 缓存
# ────────────────────────────────────────────────
REDIS_PASSWORD=HrAI_Redis_2024_Pass!

# ────────────────────────────────────────────────
# S3 对象存储（RustFS，本地自托管）
# ────────────────────────────────────────────────
MINIO_ROOT_USER=hr-admin
MINIO_ROOT_PASSWORD=HrAI_S3_2024_Pass!
S3_BUCKET=lobe
# S3 公网访问地址（本地开发使用 localhost）
S3_PUBLIC_DOMAIN=http://localhost:9000
S3_PORT=9000
S3_CONSOLE_PORT=9001

# ────────────────────────────────────────────────
# AI 模型 API 密钥（至少配置一个）
# ────────────────────────────────────────────────

# Anthropic Claude（推荐，HR Agent 默认使用）
# 获取地址：https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI（可选）
# OPENAI_API_KEY=

# Azure OpenAI（可选）
# AZURE_API_KEY=
# AZURE_API_ENDPOINT=

# ────────────────────────────────────────────────
# 功能开关（可选）
# ────────────────────────────────────────────────
# 禁止非管理员修改 API Key（多用户模式推荐开启）
# FEATURE_FLAGS="-check_updates"
