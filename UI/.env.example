# ===========================================
# HR AI 系统 - 环境变量配置
# 复制本文件为 .env.local 并填入真实值
# ===========================================

# ==================
# 基础配置
# ==================
# 应用访问地址
NEXT_PUBLIC_BASE_URL=http://localhost:3010

# 应用密钥（随机字符串，用于 session 加密）
# 生成命令: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=your-random-secret-here

# ==================
# 国内大模型配置（选择其一或多个）
# ==================

# --- 通义千问（推荐首选）---
# 阿里云 DashScope 控制台: https://dashscope.console.aliyun.com/
OPENAI_API_KEY=sk-xxx-your-qwen-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 默认模型（推荐 qwen-max，平衡速度和能力）
DEFAULT_MODEL=qwen-max
# 支持的模型列表（HR场景建议使用 qwen-max 或 qwen-plus）
# qwen-max: 最强推理，适合复杂HR分析
# qwen-plus: 速度更快，适合日常对话
# qwen-long: 超长上下文，适合处理长文档（合同/政策）

# --- 智谱 GLM（备选）---
# ZHIPU_API_KEY=your-zhipu-api-key
# 模型: glm-4-plus / glm-4-flash

# --- 文心一言（备选）---
# WENXIN_API_KEY=your-wenxin-api-key
# WENXIN_SECRET_KEY=your-wenxin-secret-key
# 模型: ERNIE-4.0-8K / ERNIE-3.5-8K

# --- DeepSeek（备选，性价比高）---
# DEEPSEEK_API_KEY=your-deepseek-api-key
# 模型: deepseek-chat / deepseek-reasoner

# ==================
# 数据库配置
# ==================
# 开发环境使用 SQLite（无需额外配置）
# 生产环境推荐 PostgreSQL

# PostgreSQL（生产环境）
# DATABASE_URL=postgresql://username:password@localhost:5432/hr_ai_db

# 如使用 SQLite（开发环境）
DATABASE_DRIVER=sqlite

# ==================
# 飞书 HR 集成
# ==================
# 飞书开放平台: https://open.feishu.cn/
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=your-feishu-app-secret

# ==================
# 钉钉 HR 集成
# ==================
# 钉钉开放平台: https://open.dingtalk.com/
DINGTALK_APP_KEY=your-dingtalk-app-key
DINGTALK_APP_SECRET=your-dingtalk-app-secret
# 企业应用 AgentID（用于发送工作通知）
DINGTALK_AGENT_ID=your-agent-id

# ==================
# SAP HR 集成
# ==================
# SAP 模式选择: hcm（SAP HCM）或 sf（SuccessFactors）
SAP_MODE=sf

# SAP SuccessFactors 配置
SAP_SF_BASE_URL=https://api{datacenter}.successfactors.com/odata/v2
SAP_SF_COMPANY_ID=your-company-id
SAP_SF_USERNAME=your-sf-username
SAP_SF_API_KEY=your-sf-api-key

# SAP HCM 配置（如使用本地 SAP 系统）
# SAP_HCM_BASE_URL=https://your-sap-server/sap/opu/odata/sap
# SAP_HCM_USERNAME=your-sap-username
# SAP_HCM_PASSWORD=your-sap-password
# SAP_CLIENT=100

# ==================
# MCP 服务器配置
# ==================
# Lobe-chat 会自动根据这里的配置启动 MCP 服务器
# 路径相对于 lobe-chat 项目根目录

# 飞书 HR MCP
MCP_FEISHU_ENABLED=true
MCP_FEISHU_COMMAND=node
MCP_FEISHU_ARGS=../mcp-hr-tools/feishu-hr/dist/index.js

# 钉钉 HR MCP
MCP_DINGTALK_ENABLED=false
MCP_DINGTALK_COMMAND=node
MCP_DINGTALK_ARGS=../mcp-hr-tools/dingtalk-hr/dist/index.js

# SAP HR MCP
MCP_SAP_ENABLED=false
MCP_SAP_COMMAND=node
MCP_SAP_ARGS=../mcp-hr-tools/sap-hr/dist/index.js

# ==================
# 功能开关
# ==================
# 是否开启知识库（RAG）功能
NEXT_PUBLIC_ENABLE_KNOWLEDGE_BASE=1

# 是否开启 HR 工作台
NEXT_PUBLIC_ENABLE_HR_WORKBENCH=1

# 是否开启访问控制（生产环境建议开启）
NEXT_PUBLIC_ENABLE_AUTH=0

# ==================
# HR 工作台配置
# ==================
# 工作台标题
NEXT_PUBLIC_HR_SYSTEM_TITLE=HR AI 智能助手系统

# 公司名称（显示在工作台）
NEXT_PUBLIC_COMPANY_NAME=您的公司名称

# HR 工作台 Logo（可选，支持 URL 或 Base64）
# NEXT_PUBLIC_HR_LOGO_URL=https://your-company.com/logo.png
